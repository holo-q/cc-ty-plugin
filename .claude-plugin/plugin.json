{
  "name": "ty-lsp",
  "version": "2.1.0",
  "description": "Python language server using ty - an extremely fast type checker by Astral",
  "author": {
    "name": "Astral Software Inc."
  },
  "repository": "https://github.com/astral-sh/ty",
  "license": "MIT",
  "keywords": ["python", "lsp", "language-server", "type-checking", "ty", "astral"],
  "lspServers": {
    "ty": {
      "command": "ty",
      "args": ["server"],
      "extensionToLanguage": {
        ".py": "python",
        ".pyi": "python"
      }
    }
  },
  "mcpServers": {
    "ty-lsp-extended": {
      "command": "uvx",
      "args": ["cc-lsp-now"],
      "env": {
        "LSP_SERVERS": "ty server;basedpyright-langserver --stdio",
        "LSP_PREFER": "workspace/willRenameFiles=basedpyright-langserver,textDocument/prepareCallHierarchy=basedpyright-langserver,callHierarchy/incomingCalls=basedpyright-langserver,callHierarchy/outgoingCalls=basedpyright-langserver"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "LSP",
        "hooks": [
          {
            "type": "command",
            "command": "cc-lsp-now-redirect-hook"
          }
        ]
      }
    ]
  }
}
