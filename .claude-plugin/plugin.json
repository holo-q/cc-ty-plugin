{
  "name": "ty-lsp",
  "version": "1.3.0",
  "description": "Python language server using ty - an extremely fast type checker by Astral",
  "author": {
    "name": "Astral Software Inc."
  },
  "repository": "https://github.com/astral-sh/ty",
  "license": "MIT",
  "keywords": ["python", "lsp", "language-server", "type-checking", "ty", "astral"],
  "lspServers": {
    "ty": {
      "command": "ty",
      "args": ["server"],
      "extensionToLanguage": {
        ".py": "python",
        ".pyi": "python"
      }
    }
  },
  "mcpServers": {
    "ty-lsp-extended": {
      "command": "uvx",
      "args": ["cc-lsp-now"],
      "env": {
        "LSP_COMMAND": "ty",
        "LSP_ARGS": "server",
        "LSP_FALLBACK_COMMAND": "basedpyright-langserver",
        "LSP_FALLBACK_ARGS": "--stdio"
      }
    }
  }
}
